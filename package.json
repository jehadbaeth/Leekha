{
  "name": "leekha",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "test": "pnpm -r --filter=\"./packages/**\" --filter=\"./apps/server\" test run",
    "sim": "pnpm --filter tools-sim run start --",
    "duel": "pnpm --filter tools-sim run duel --",
    "replay": "pnpm --filter tools-sim run replay --",
    "build": "pnpm -r --filter=./packages/** build"
  }
}
